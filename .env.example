# OpenRouter API Credentials
# Replace with your actual key to run in live mode
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Simulation / Mock Mode Settings
# Set HYDRA_MOCK=true to simulate failovers and rate limits without hit live APIs
HYDRA_MOCK=true

# Mock status overrides for each head (AVAILABLE, UNAVAILABLE, RATE_LIMITED, FAILED)
MOCK_STATUS_NORTH_MINI=RATE_LIMITED
MOCK_STATUS_GEMMA=AVAILABLE
